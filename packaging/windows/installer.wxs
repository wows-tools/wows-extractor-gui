<?xml version="1.0" encoding="UTF-8"?>
<!--
  WiX v3 installer for WoWS Extractor.
  AppFiles.wxs is auto-generated by heat.exe from the staging/bin directory.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <Product
    Id="*"
    Name="WoWS Extractor"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="kakwa"
    UpgradeCode="E8A3C5D2-F1B6-4E7A-9C0D-2B3E4F5A6D7C">

    <Package
      InstallerVersion="405"
      Compressed="yes"
      InstallScope="perMachine"
      Description="World of Warships Asset Extractor" />

    <!-- Prevent downgrade, silently remove old version on upgrade -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of WoWS Extractor is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <!-- ── Directory layout ───────────────────────────────────────── -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="WoWS Extractor" />
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="AppMenuFolder" Name="WoWS Extractor" />
      </Directory>
    </Directory>

    <!-- ── Start Menu shortcut ───────────────────────────────────── -->
    <DirectoryRef Id="AppMenuFolder">
      <Component Id="ApplicationShortcut" Guid="*">
        <Shortcut
          Id="AppStartMenuShortcut"
          Name="WoWS Extractor"
          Description="World of Warships Asset Extractor"
          Target="[INSTALLDIR]wows-extractor.exe"
          WorkingDirectory="INSTALLDIR" />
        <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
        <RegistryValue
          Root="HKCU"
          Key="Software\kakwa\WoWSExtractor"
          Name="installed"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <!-- ── Features ──────────────────────────────────────────────── -->
    <Feature Id="ProductFeature" Title="WoWS Extractor" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>

    <!-- Minimal UI (just license + progress) -->
    <UIRef Id="WixUI_Minimal" />

  </Product>
</Wix>
